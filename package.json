{
  "name": "laraboxs-windows",
  "version": "0.1.2",
  "description": "Windows-first local development manager for PHP and Laravel projects.",
  "private": true,
  "license": "MIT",
  "author": "laraboxs contributors",
  "type": "module",
  "keywords": [
    "laravel",
    "php",
    "windows",
    "local-development",
    "nginx",
    "mysql",
    "mariadb",
    "redis",
    "tauri"
  ],
  "os": [
    "win32"
  ],
  "bin": {
    "laraboxs": "./dist/cli/index.js"
  },
  "scripts": {
    "api": "tsx src/api/server.ts",
    "build": "tsc -p tsconfig.node.json && vite build",
    "check": "npm run typecheck && npm run test && npm run build",
    "clean": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"Remove-Item -Recurse -Force dist,dist-ui,coverage,artifacts -ErrorAction SilentlyContinue; Remove-Item -Force *.tsbuildinfo -ErrorAction SilentlyContinue\"",
    "api:watch": "tsx watch src/api/server.ts",
    "cli": "tsx src/cli/index.ts",
    "cli:watch": "tsx watch src/cli/index.ts",
    "dev": "vite --host 127.0.0.1",
    "dev:tauri-prep": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-laraboxs-dev.ps1",
    "dev:tauri": "npm run dev:tauri-prep && npm run dev",
    "helper:install": "powershell -ExecutionPolicy Bypass -File scripts/install-helper-service.ps1",
    "helper:status": "powershell -ExecutionPolicy Bypass -File scripts/helper-service-status.ps1",
    "helper:uninstall": "powershell -ExecutionPolicy Bypass -File scripts/uninstall-helper-service.ps1",
    "package:preview": "powershell -ExecutionPolicy Bypass -File scripts/package-preview.ps1",
    "package:tauri-resources": "powershell -ExecutionPolicy Bypass -File scripts/prepare-tauri-resources.ps1",
    "start": "node dist/api/server.js",
    "tauri": "tauri",
    "tauri:dev": "npm run dev:tauri-prep && tauri dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "extract-zip": "^2.0.1",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.1.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.6"
  }
}
